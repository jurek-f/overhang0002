# Copy to .env.local for local development.
# Set in Vercel project settings → Environment Variables for production.

# Optional: gates the app behind a passcode screen.
VITE_ACCESS_PASSCODE=your_passcode_here

# API keys — when set here, they take priority over anything entered in the settings drawer.
# All keys are embedded in the client bundle at build time (VITE_ prefix).
# Only use for personal / access-gated deployments.
VITE_DEEPGRAM_KEY=
VITE_ELEVENLABS_KEY=
VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
VITE_ANTHROPIC_KEY=
VITE_GEMINI_KEY=
