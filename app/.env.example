# Copy to .env.local for local development.
# Set in Vercel project settings → Environment Variables for production.

# Optional: gates the app behind a passcode screen.
ACCESS_PASSCODE=your_passcode_here

# API keys — injected at build time via vite.config.ts define block.
# Only the vars listed here are exposed to the browser bundle.
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
